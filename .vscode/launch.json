{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug C++20 Program",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/matrix_test", // 替换为你的可执行文件路径
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build", // 确保有一个名为 "build" 的任务用于编译程序
            "miDebuggerPath": "/usr/bin/gdb" // 根据你的系统调整 GDB 路径
        }
    ]
}